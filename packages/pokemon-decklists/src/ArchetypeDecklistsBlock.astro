---
import type { Decklist } from "./domain.js";
import DecklistBlock from "./DecklistBlock.astro";

interface Props { node: { archetypeId?: string; showCards?: boolean } }
const { node } = Astro.props;
let decks: Decklist[] = [];
if (node.archetypeId) {
	try {
		const endpoint = new URL("/_emdash/api/plugins/pokemon-decklists/decks", Astro.url.origin);
		endpoint.searchParams.set("archetypeId", node.archetypeId);
		const response = await fetch(endpoint);
		if (response.ok) { const body = await response.json(); decks = (body.data ?? body).items ?? []; }
	} catch { /* Render the empty state. */ }
}
const spriteUrl = (deck: Decklist, index: number) => {
	const pokemon = deck.archetypePokemon?.[index];
	const id = pokemon && (pokemon.spriteId ?? pokemon.speciesId);
	return id ? `https://cdn.tcghub.cl/sprites/sprites/pokemon/${id}.png` : undefined;
};
---

<section class="archetype-decks">
	<header><p>LISTAS DEL ARQUETIPO</p><h3>{decks[0]?.archetypeName ?? "Decklists"}</h3><span>{decks.length} {decks.length === 1 ? "lista" : "listas"}</span></header>
	{decks.length ? (
		<div class="table-wrap"><table>
			<thead><tr><th>Pokémon</th><th>Lista</th><th>Formato</th><th>Decklist</th></tr></thead>
			<tbody>{decks.map((deck) => <tr><td><div class="sprites">{[0, 1].map((index) => spriteUrl(deck, index) && <img src={spriteUrl(deck, index)} alt={deck.archetypePokemon[index]?.name ?? "Pokémon"} width="42" height="42" loading="lazy" />)}</div></td><th>{deck.name}</th><td>{deck.format.toUpperCase()}</td><td><button class="viewer-trigger" type="button" data-open-deck={`archetype-deck-${deck.id}`} aria-controls={`archetype-deck-${deck.id}`} aria-haspopup="dialog" aria-label={`Visualizar ${deck.name}`} title={`Visualizar ${deck.name}`}><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 12s3.5-6 9.5-6 9.5 6 9.5 6-3.5 6-9.5 6-9.5-6-9.5-6Z"/><circle cx="12" cy="12" r="2.75"/></svg></button></td></tr>)}</tbody>
		</table></div>
	) : <p class="empty">Todavía no hay decklists para este arquetipo.</p>}
	{node.showCards !== false && decks.map((deck) => (
		<dialog class="deck-modal" id={`archetype-deck-${deck.id}`} aria-labelledby={`archetype-deck-title-${deck.id}`}>
			<div class="deck-modal__content">
				<DecklistBlock chrome="modal" titleId={`archetype-deck-title-${deck.id}`} node={{ deckId: deck.id, displayMode: "both", showResults: false }} />
			</div>
		</dialog>
	))}
</section>

<script>
	document.addEventListener("click", (event) => {
		const target = event.target as HTMLElement;
		const openButton = target.closest<HTMLButtonElement>("[data-open-deck]");
		if (openButton?.dataset.openDeck) {
			const dialog = document.getElementById(openButton.dataset.openDeck) as HTMLDialogElement | null;
			// ponytail: defer so the same click doesn't light-dismiss the freshly opened dialog
			queueMicrotask(() => dialog?.showModal());
			return;
		}
		const closeButton = target.closest<HTMLButtonElement>("[data-close-deck]");
		if (closeButton) {
			closeButton.closest<HTMLDialogElement>("dialog")?.close();
			return;
		}
		if (target instanceof HTMLDialogElement && target.classList.contains("deck-modal")) target.close();
	});
</script>

<style>
	.archetype-decks { margin: 2.5rem 0; border: 1px solid color-mix(in srgb, currentColor 16%, transparent); border-radius: 1.25rem; overflow: hidden; }
	header { padding: 1.4rem clamp(1rem,4vw,2rem); display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap; }
	header p { width: 100%; margin: 0; font-size: .7rem; letter-spacing: .14em; opacity: .6; } h3 { margin: 0; font-size: 1.5rem; } header span { opacity: .58; font-size: .82rem; }
	.table-wrap { overflow-x: auto; border-top: 1px solid color-mix(in srgb, currentColor 14%, transparent); } table { width: 100%; min-width: 540px; border-collapse: collapse; font-size: .82rem; } th,td { padding: .65rem .85rem; text-align: left; border-bottom: 1px solid color-mix(in srgb, currentColor 10%, transparent); } thead th { font-size: .7rem; letter-spacing: .08em; text-transform: uppercase; opacity: .62; } tbody th { font-weight: 650; }
	.viewer-trigger, [data-close-deck] { display: grid; place-items: center; width: 34px; height: 34px; padding: 0; border: 1px solid color-mix(in srgb, currentColor 18%, transparent); border-radius: 999px; color: inherit; background: transparent; cursor: pointer; }
	.viewer-trigger:hover, [data-close-deck]:hover { background: color-mix(in srgb, currentColor 9%, transparent); }
	.viewer-trigger svg, [data-close-deck] svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; stroke-linejoin: round; }
	.sprites { display: flex; align-items: center; min-width: 70px; } .sprites img { width: 42px; height: 42px; object-fit: contain; } .sprites img + img { margin-left: -.6rem; }
	.deck-modal { width: min(920px, calc(100vw - 2rem)); max-width: none; max-height: calc(100dvh - 2rem); margin: auto; padding: 0; border: 1px solid color-mix(in srgb, currentColor 20%, transparent); border-radius: 1rem; color: inherit; background: var(--color-background, #101010); box-shadow: 0 24px 80px #000b; overflow: hidden; }
	.deck-modal::backdrop { background: #000b; backdrop-filter: blur(4px); }
	.deck-modal__content { min-height: 0; max-height: calc(100dvh - 2rem); overflow-y: auto; }
	.deck-modal__content :global(.tcg-deck) { margin: 0; }
	.empty { padding: 0 2rem 1.5rem; opacity: .65; }
	@media(max-width:600px){ .archetype-decks { margin-inline: -.5rem; } }
</style>
