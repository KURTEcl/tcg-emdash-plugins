---
import type { DeckCard, Decklist, MatchResult } from "./domain.js";
import { serializePokemonDecklist } from "./parser.js";

interface Props {
	node: { deckId?: string; displayMode?: "images" | "text" | "both"; showResults?: boolean };
	/** Modal chrome: one header with copy + close (no outer modal title bar). */
	chrome?: "default" | "modal";
	titleId?: string;
}

const { node, chrome = "default", titleId } = Astro.props;
const isModal = chrome === "modal";
const displayMode = node.displayMode ?? "both";
let deck: Decklist | null = null;
let matches: MatchResult[] = [];
let stats = { total: 0, wins: 0, losses: 0, draws: 0, winRate: 0 };

if (node.deckId) {
	try {
		const endpoint = new URL("/_emdash/api/plugins/pokemon-decklists/decks", Astro.url.origin);
		endpoint.searchParams.set("id", node.deckId);
		const response = await fetch(endpoint);
		if (response.ok) {
			const body = await response.json();
			// ponytail: `{ data: null }` is truthy via `?? body` — only accept a real deck
			const payload = body.data ?? body;
			deck = Array.isArray(payload?.cards) ? payload : null;
		}
		if (node.showResults) {
			const resultsEndpoint = new URL("/_emdash/api/plugins/pokemon-decklists/matches", Astro.url.origin);
			resultsEndpoint.searchParams.set("deckId", node.deckId);
			const resultResponse = await fetch(resultsEndpoint);
			if (resultResponse.ok) {
				const body = await resultResponse.json();
				const payload = body.data ?? body;
				matches = Array.isArray(payload?.items) ? payload.items : [];
				stats = payload?.stats ?? stats;
			}
		}
	} catch { /* The block renders a helpful empty state below. */ }
}

const text = deck ? serializePokemonDecklist(deck.cards) : "";
const cards = deck ? (["pokemon", "trainer", "energy"] as const).flatMap((category) => deck!.cards.filter((card) => card.category === category)) : [];
const showCards = displayMode !== "text";
const showText = displayMode !== "images";
const showResultsTab = Boolean(node.showResults && stats.total > 0);
const showTabs = (showCards && showText) || showResultsTab;
const defaultTab = showCards ? "cards" : showText ? "text" : "results";
const instanceId = crypto.randomUUID();
const copyId = `deck-copy-${instanceId}`;
const cardDialogId = `deck-card-dialog-${instanceId}`;
const lowImageUrl = (url?: string) => url?.replace(/\/high\.webp(?:\?.*)?$/, "/low.webp");
const sprites = (deck?.archetypePokemon ?? []).slice(0, 2).flatMap((pokemon) => {
	const id = pokemon.spriteId ?? pokemon.speciesId;
	return id ? [{ ...pokemon, url: `https://cdn.tcghub.cl/sprites/sprites/pokemon/${id}.png` }] : [];
});
const opponentSprites = (match: MatchResult) => (match.opponentPokemon ?? []).slice(0, 2).flatMap((pokemon) => {
	const id = pokemon.spriteId ?? pokemon.speciesId;
	return id ? [{ name: pokemon.name, url: `https://cdn.tcghub.cl/sprites/sprites/pokemon/${id}.png` }] : [];
});
---

{deck ? (
	<section class:list={["tcg-deck", { "tcg-deck--modal": isModal }]} data-deck={deck.id}>
		<header class="tcg-deck__header">
			<div>
				<p class="tcg-deck__eyebrow">DECKLIST · {deck.format.toUpperCase()}</p>
				<div class="tcg-deck__title" id={titleId}>{deck.name}</div>
			</div>
			<div class="tcg-deck__header-actions">
				{sprites.length > 0 && <div class="tcg-deck__sprites">{sprites.map((sprite) => <img class="tcg-deck__sprite" src={sprite.url} alt={sprite.name} width="56" height="56" loading="lazy" />)}</div>}
				<button class="tcg-deck__copy" type="button" data-copy-target={copyId} data-copy-text={text} aria-label="Copiar lista" title="Copiar lista"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 8h10v10H8zM6 16H4V4h12v2" /></svg><span>Copiar lista</span></button>
				{isModal && <button class="tcg-deck__close" type="button" data-close-deck aria-label="Cerrar visualizador" title="Cerrar"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"/></svg></button>}
			</div>
		</header>

		{showTabs && (
			<div class="tcg-deck__tabs" role="tablist" aria-label="Vista del decklist">
				{showCards && <button type="button" role="tab" aria-selected={defaultTab === "cards"} data-deck-tab="cards">Cartas</button>}
				{showText && <button type="button" role="tab" aria-selected={defaultTab === "text"} data-deck-tab="text">Lista</button>}
				{showResultsTab && <button type="button" role="tab" aria-selected={defaultTab === "results"} data-deck-tab="results">Resultados</button>}
			</div>
		)}
		{showCards && <div class="tcg-deck__panel" data-deck-panel="cards" hidden={showTabs && defaultTab !== "cards"}><div class="tcg-deck__cards">{cards.map((card: DeckCard) => <figure class:list={["tcg-card", { "tcg-card--missing": !card.displayPrinting.imageUrl }]}><button class="tcg-card__open" type="button" data-card-open data-card-name={card.displayPrinting.name} data-card-quantity={card.quantity} data-card-set={card.displayPrinting.setCode ?? card.importedPrinting.setCode ?? ""} data-card-number={card.displayPrinting.collectorNumber ?? card.importedPrinting.collectorNumber ?? ""} data-card-rarity={card.displayPrinting.rarity ?? ""} data-card-image={card.displayPrinting.imageUrl ?? ""} data-card-search={`/decklists?card=${encodeURIComponent(card.displayPrinting.name)}`} aria-label={`Ver detalles de ${card.displayPrinting.name}`} title={`Ver detalles de ${card.displayPrinting.name}`}><span class="tcg-card__image">{card.displayPrinting.imageUrl ? <img src={lowImageUrl(card.displayPrinting.imageUrl)} alt={card.displayPrinting.name} loading="lazy" decoding="async" /> : <span class="tcg-card__placeholder">{card.displayPrinting.name}</span>}<strong class="tcg-card__quantity" aria-label={`${card.quantity} copias`}>{card.quantity}</strong></span></button></figure>)}</div></div>}
		{showText && <div class="tcg-deck__panel" data-deck-panel="text" hidden={showTabs ? defaultTab !== "text" : false}><pre class="tcg-deck__text" id={copyId}>{text}</pre></div>}
		{showResultsTab && (
			<div class="tcg-deck__panel" data-deck-panel="results" hidden={defaultTab !== "results"}>
				<section class="tcg-results">
					<div class="tcg-results__summary"><strong>{stats.winRate}%</strong><span>win rate · {stats.total} rondas</span></div>
					<div class="tcg-results__numbers"><span>{stats.wins} W</span><span>{stats.losses} L</span><span>{stats.draws} T</span></div>
					<ul>{matches.slice(0, 8).map((match) => {
						const rivals = opponentSprites(match);
						return <li>
							<span class="tcg-results__row">
								{rivals.length > 0 && <span class="tcg-results__sprites" title={match.opponentArchetype}>{rivals.map((sprite) => <img src={sprite.url} alt={sprite.name} title={sprite.name} width="28" height="28" loading="lazy" />)}</span>}
								<span>
									{match.tournamentId
										? <a class="tcg-results__event" href={`/results/${match.tournamentId}`}>{match.eventName ?? "Torneo"}</a>
										: (match.eventName ?? match.playedAt)}
									{match.round ? ` · R${match.round}` : ""}
									{match.videoUrl ? <> · <a class="tcg-results__video" href={match.videoUrl} target="_blank" rel="noopener noreferrer">Ver video</a></> : null}
								</span>
							</span>
							<strong class={`is-${match.result}`}>{match.result === "win" ? "W" : match.result === "loss" ? "L" : "T"}</strong>
						</li>;
					})}</ul>
				</section>
			</div>
		)}

		<dialog class="tcg-card-modal" id={cardDialogId} data-card-dialog aria-labelledby={`${cardDialogId}-title`}>
			<div class="tcg-card-modal__shell">
				<div class="tcg-card-modal__bar"><strong id={`${cardDialogId}-title`} data-card-modal-title>Detalle de la carta</strong><button type="button" data-card-close aria-label="Cerrar detalle de la carta" title="Cerrar"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18"/></svg></button></div>
				<div class="tcg-card-modal__body"><div class="tcg-card-modal__media" data-card-modal-media></div><div class="tcg-card-modal__info"><p data-card-modal-quantity></p><dl><div data-card-modal-set-row><dt>Colección</dt><dd data-card-modal-set></dd></div><div data-card-modal-number-row><dt>Número</dt><dd data-card-modal-number></dd></div><div data-card-modal-rarity-row><dt>Rareza</dt><dd data-card-modal-rarity></dd></div></dl><a data-card-modal-search href="/decklists">Ver otros decklists con esta carta <span aria-hidden="true">→</span></a></div></div>
			</div>
		</dialog>
	</section>
) : (
	<aside class="tcg-deck tcg-deck--empty">Selecciona un decklist válido o comprueba que siga publicado en el panel.</aside>
)}

<script>
	document.addEventListener("click", async (event) => {
		const target = event.target as HTMLElement;
		const cardButton = target.closest<HTMLButtonElement>("[data-card-open]");
		if (cardButton) {
			const deck = cardButton.closest<HTMLElement>("[data-deck]");
			const dialog = deck?.querySelector<HTMLDialogElement>("[data-card-dialog]");
			if (!dialog) return;
			const name = cardButton.dataset.cardName ?? "Carta";
			const imageUrl = cardButton.dataset.cardImage;
			const media = dialog.querySelector<HTMLElement>("[data-card-modal-media]");
			const title = dialog.querySelector<HTMLElement>("[data-card-modal-title]");
			const quantity = dialog.querySelector<HTMLElement>("[data-card-modal-quantity]");
			const search = dialog.querySelector<HTMLAnchorElement>("[data-card-modal-search]");
			if (title) title.textContent = name;
			if (quantity) quantity.textContent = `${cardButton.dataset.cardQuantity ?? "1"} ${cardButton.dataset.cardQuantity === "1" ? "copia en esta lista" : "copias en esta lista"}`;
			if (media) { media.replaceChildren(); if (imageUrl) { const image = document.createElement("img"); image.src = imageUrl; image.alt = name; media.append(image); } }
			for (const field of ["set", "number", "rarity"] as const) {
				const value = cardButton.dataset[`card${field[0].toUpperCase()}${field.slice(1)}` as "cardSet" | "cardNumber" | "cardRarity"] ?? "";
				const row = dialog.querySelector<HTMLElement>(`[data-card-modal-${field}-row]`);
				const output = dialog.querySelector<HTMLElement>(`[data-card-modal-${field}]`);
				if (row) row.hidden = !value;
				if (output) output.textContent = value;
			}
			if (search) search.href = cardButton.dataset.cardSearch ?? "/decklists";
			dialog.showModal();
			return;
		}
		const cardClose = target.closest<HTMLButtonElement>("[data-card-close]");
		if (cardClose) { cardClose.closest<HTMLDialogElement>("dialog")?.close(); return; }
		if (target instanceof HTMLDialogElement && target.classList.contains("tcg-card-modal")) { target.close(); return; }
		const tab = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-deck-tab]");
		if (tab) {
			const deck = tab.closest<HTMLElement>("[data-deck]");
			if (!deck) return;
			const selected = tab.dataset.deckTab;
			deck.querySelectorAll<HTMLButtonElement>("[data-deck-tab]").forEach((item) => item.setAttribute("aria-selected", String(item === tab)));
			deck.querySelectorAll<HTMLElement>("[data-deck-panel]").forEach((panel) => { panel.hidden = panel.dataset.deckPanel !== selected; });
			return;
		}
		const button = (event.target as HTMLElement).closest<HTMLButtonElement>("[data-copy-text]");
		if (!button) return;
		await navigator.clipboard.writeText(button.dataset.copyText ?? "");
		button.classList.add("is-copied");
		button.setAttribute("aria-label", "Lista copiada");
		setTimeout(() => { button.classList.remove("is-copied"); button.setAttribute("aria-label", "Copiar lista"); }, 1800);
	});
</script>

<style>
	.tcg-deck { --deck-line: color-mix(in srgb, currentColor 16%, transparent); margin: 1.75rem 0; border: 1px solid var(--deck-line); border-radius: 1rem; overflow: hidden; background: color-mix(in srgb, var(--color-background, #0b0b0b) 94%, currentColor 6%); }
	.tcg-deck__header { display: flex; justify-content: space-between; gap: .75rem; align-items: center; padding: .85rem 1rem; border-bottom: 1px solid var(--deck-line); }
	.tcg-deck__eyebrow { margin: 0 0 .2rem; font-size: .62rem; letter-spacing: .12em; opacity: .6; }
	.tcg-deck__title { margin: 0; font-size: clamp(1.1rem, 3vw, 1.35rem); font-weight: 700; line-height: 1.2; }
	.tcg-deck__header-actions,.tcg-deck__sprites { display: flex; align-items: center; }
	.tcg-deck__header-actions { gap: .5rem; }
	.tcg-deck__sprites { gap: .1rem; }
	.tcg-deck__sprite { width: 48px; height: 48px; object-fit: contain; image-rendering: auto; flex: 0 0 auto; }
	.tcg-deck__copy, .tcg-deck__close { width: 36px; height: 36px; display: grid; place-items: center; padding: 0; border: 1px solid var(--deck-line); border-radius: 999px; color: inherit; background: transparent; cursor: pointer; }
	.tcg-deck__copy svg, .tcg-deck__close svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; }
	.tcg-deck__copy span { position: absolute; width: 1px; height: 1px; overflow: hidden; clip-path: inset(50%); }
	.tcg-deck__copy.is-copied { color: #39a96b; border-color: currentColor; }
	.tcg-deck--modal { border-radius: 0; border: 0; background: transparent; }
	.tcg-deck--modal .tcg-deck__header { padding-inline: 1rem; }
	.tcg-deck__tabs { display: flex; gap: .25rem; padding: .55rem .75rem; border-bottom: 1px solid var(--deck-line); }
	.tcg-deck__tabs button { padding: .35rem .75rem; border: 0; border-radius: 999px; color: inherit; background: transparent; font: 600 .72rem/1 inherit; cursor: pointer; opacity: .62; }
	.tcg-deck__tabs button[aria-selected="true"] { background: color-mix(in srgb, currentColor 10%, transparent); opacity: 1; }
	.tcg-deck__panel[hidden] { display: none; }
	.tcg-deck__panel { margin: 0 !important; padding: .3rem .6rem .6rem; }
	.tcg-deck__cards { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: .25rem; margin: 0 !important; padding: 0; }
	.tcg-deck__cards > .tcg-card { min-width: 0; margin: 0 !important; }
	.tcg-card__open { display: block; width: 100%; padding: 0; border: 0; border-radius: .55rem; color: inherit; background: transparent; cursor: pointer; }
	.tcg-card__open:focus-visible { outline: 2px solid currentColor; outline-offset: 2px; }
	.tcg-card__image { position: relative; width: 100%; aspect-ratio: 245 / 342; }
	.tcg-card img, .tcg-card__placeholder { display: block; width: 100%; height: 100%; border-radius: .55rem; object-fit: cover; background: color-mix(in srgb, currentColor 8%, transparent); }
	.tcg-card__placeholder { padding: .75rem; box-sizing: border-box; display: grid; place-items: center; text-align: center; font-size: .78rem; }
	.tcg-card__quantity { position: absolute; bottom: .3rem; left: .3rem; min-width: 1.45rem; height: 1.45rem; display: grid; place-items: center; padding: 0 .25rem; border: 2px solid white; border-radius: 999px; color: white; background: #d72638; box-shadow: 0 2px 8px #0009; font: 800 .75rem/1 sans-serif; }
	.tcg-card-modal { width: min(760px, calc(100vw - 2rem)); max-width: none; max-height: calc(100dvh - 2rem); margin: auto; padding: 0; border: 1px solid var(--deck-line); border-radius: 1rem; color: inherit; background: var(--color-background, #101010); box-shadow: 0 24px 80px #000b; overflow: hidden; }
	.tcg-card-modal::backdrop { background: #000b; backdrop-filter: blur(4px); }
	.tcg-card-modal__shell { display: grid; grid-template-rows: auto minmax(0,1fr); max-height: calc(100dvh - 2rem); }
	.tcg-card-modal__bar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: .75rem 1rem; border-bottom: 1px solid var(--deck-line); }
	.tcg-card-modal__bar > strong { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
	.tcg-card-modal__bar button { display: grid; place-items: center; width: 34px; height: 34px; flex: 0 0 auto; padding: 0; border: 1px solid var(--deck-line); border-radius: 999px; color: inherit; background: transparent; cursor: pointer; }
	.tcg-card-modal__bar svg { width: 17px; height: 17px; fill: none; stroke: currentColor; stroke-width: 1.7; stroke-linecap: round; }
	.tcg-card-modal__body { display: grid; grid-template-columns: minmax(220px, .8fr) 1fr; gap: 1.25rem; min-height: 0; overflow-y: auto; padding: 1rem; }
	.tcg-card-modal__media { min-height: 220px; }
	.tcg-card-modal__media :global(img) { display: block; width: 100%; max-height: calc(100dvh - 8rem); margin: 0; border-radius: .75rem; object-fit: contain; }
	.tcg-card-modal__info { align-self: center; }
	.tcg-card-modal__info > p { margin: 0 0 1rem; font-weight: 700; }
	.tcg-card-modal__info dl { margin: 0 0 1.25rem; }
	.tcg-card-modal__info dl div { display: flex; justify-content: space-between; gap: 1rem; padding: .55rem 0; border-bottom: 1px solid var(--deck-line); }
	.tcg-card-modal__info dt { opacity: .62; }
	.tcg-card-modal__info dd { margin: 0; text-align: right; }
	.tcg-card-modal .tcg-card-modal__info a { display: inline-flex; align-items: center; gap: .5rem; padding: .7rem 1rem; border-radius: 999px; color: var(--color-on-brand, white); background: var(--color-brand, #d72638); font-weight: 700; text-decoration: none; }
	.tcg-deck__text { margin: 0; white-space: pre-wrap; overflow-x: auto; font: .76rem/1.55 ui-monospace, SFMono-Regular, Menlo, monospace; }
	.tcg-results { padding: .5rem .25rem .25rem; }
	.tcg-results__summary { display: flex; align-items: baseline; gap: .6rem; }
	.tcg-results__summary strong { font-size: 2rem; }
	.tcg-results__numbers { display: flex; gap: .8rem; margin: .45rem 0 1rem; opacity: .65; }
	.tcg-results ul { list-style: none; margin: 0; padding: 0; }
	.tcg-results li { display: flex; justify-content: space-between; gap: 1rem; align-items: center; padding: .65rem 0; border-top: 1px solid var(--deck-line); font-size: .82rem; }
	.tcg-results__row { display: inline-flex; align-items: center; gap: .55rem; min-width: 0; }
	.tcg-results__sprites { display: inline-flex; align-items: center; flex: 0 0 auto; }
	.tcg-results__sprites img { width: 28px; height: 28px; object-fit: contain; }
	.tcg-results__sprites img + img { margin-left: -.45rem; }
	.tcg-results .is-win { color: #39a96b; } .tcg-results .is-loss { color: #d85b5b; }
	.tcg-results__event, .tcg-results__video { color: inherit; font-weight: 700; text-decoration: underline; text-underline-offset: .15em; }
	.tcg-deck--empty { padding: 1.25rem; }
	@media (max-width: 760px) { .tcg-deck__cards { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
	@media (max-width: 600px) { .tcg-deck { margin-inline: -.5rem; border-radius: .85rem; } .tcg-deck__header { padding: .7rem .75rem; } .tcg-deck__sprite { width: 38px; height: 38px; } .tcg-deck__sprites img:nth-child(2) { display: none; } .tcg-deck__cards { grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .25rem; } .tcg-deck__panel { padding: .25rem .5rem .5rem; } .tcg-card-modal__body { grid-template-columns: 1fr; } .tcg-card-modal__media { min-height: 0; } .tcg-card-modal__media :global(img) { max-height: 55dvh; } }
</style>
